# ── Authentication (NextAuth + GitHub OAuth) ─────────────────────────────────
# Leave GITHUB_CLIENT_ID/SECRET blank to run WITHOUT login (dev mode): the app
# uses the Settings → Identity switcher and trusts an x-cms-user header. Set
# both to require real GitHub sign-in — the x-cms-user header is then ignored
# server-side and role is resolved from CMS-content/users.json (accounts not in
# that file are denied access).
#
# Register a GitHub OAuth App at https://github.com/settings/developers:
#   - Homepage URL:           http://localhost:3000  (your origin in prod)
#   - Authorization callback: http://localhost:3000/api/auth/callback/github
#                             (register a second OAuth App for the prod origin)
# The requested scope (read:user user:email) is set in code.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Personal Access Token (for content API - needs repo scope)
GITHUB_TOKEN=

# Repository in "owner/repo" format
GITHUB_REPO=beqom-emu/kb-front-end

# Default branch — the base branch for published PRs
GITHUB_DEFAULT_BRANCH=main

# Default project — which project under CMS-content/projects/<slug>/ content
# resolves to. Defaults to "accelerate" (the migrated single project). Leave
# unset unless you've renamed/added projects. (Per-request project selection
# arrives in a later phase.)
CMS_DEFAULT_PROJECT=accelerate

# Working branch — every editor save (including autosave) targets this branch
# instead of GITHUB_DEFAULT_BRANCH. The /api/publish flow opens a PR from this
# branch into the default branch. Created automatically if missing.
# Leave unset to fall back to direct commits on the default branch (not recommended).
CMS_WORKING_BRANCH=cms-drafts

# NextAuth — required when GITHUB_CLIENT_ID/SECRET are set.
# Generate the secret with:  openssl rand -base64 32
# NEXTAUTH_URL must match the origin the app is served from.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub webhook secret — enables the post-merge hook that marks articles
# "Published" when their publish PR merges. Leave blank to disable (the
# /api/webhooks/github endpoint then returns 503 and nothing is marked).
# Generate with:  openssl rand -hex 32
# Configure in the repo: Settings → Webhooks → Add webhook
#   - Payload URL:   <origin>/api/webhooks/github
#   - Content type:  application/json
#   - Secret:        same value as below
#   - Events:        "Let me select…" → Pull requests
GITHUB_WEBHOOK_SECRET=

# ── Notifications ────────────────────────────────────────────────────────────
# Both blocks are optional — without them, lib/notifications.ts logs to the
# server console instead of sending. The app keeps working in either case.

# Resend — https://resend.com (100 emails/day free, no payment)
# Without RESEND_FROM_EMAIL, falls back to onboarding@resend.dev (only delivers
# to the email address that owns the Resend account — fine for testing).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Slack incoming webhook — posts to a single channel.
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Public URL the app is reachable at — used to build deep links inside Slack
# messages. Falls back to the request's own origin if unset.
CMS_PUBLIC_URL=

# ── Zendesk (Guide) ──
# Outbound sync: publishes the TOC + articles into a help centre. Never commit
# real values — put them in .env.local (gitignored).
#
# Account subdomain, e.g. "beqom" → beqom.zendesk.com. This is the ACCOUNT, used
# to list brands and authenticate; the per-project brand you pick in
# Zendesk → "Publishing to" is what routes each help-centre call.
ZENDESK_SUBDOMAIN=

# An agent email. Auth is HTTP Basic as `{email}/token:{api_token}`.
ZENDESK_EMAIL=

# API token: Admin Center → Apps and integrations → APIs → Zendesk API tokens.
ZENDESK_API_TOKEN=

# Guide permission group id — required to CREATE articles. Find it via
# GET /api/v2/guide/permission_groups.json
ZENDESK_PERMISSION_GROUP_ID=
